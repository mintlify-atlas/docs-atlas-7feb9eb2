    "CBridgeFacet - Celer cBridge integration",
    "GenericSwapFacet - Generic DEX swap functionality",
    "SwapperV2 - Advanced swap aggregator",
    "LiFiDiamond - Main diamond proxy contract",
    "Executor - Transaction execution contract",
    "DiamondCutFacet - Diamond upgrade functionality",
    "DiamondLoupeFacet - Diamond introspection",
    "OwnershipFacet - Contract ownership management",
    "FeeCollector - Fee collection and distribution",
    "WhitelistManagerFacet - Address whitelist management",
    "Permit2Proxy - ERC20 Permit2 integration",
    "factories - Contract factory exports for all facets"
